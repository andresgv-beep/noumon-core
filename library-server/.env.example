PORT=8090
BIND=0.0.0.0
CLIENT_ORIGINS=http://localhost:5173
# Obligatorio para crear el primer admin desde otro equipo de la LAN.
NOUMON_SETUP_TOKEN=cambia-este-codigo
# Carril máquina opcional. Si se activa, use 32 caracteres aleatorios como mínimo.
# NOUMON_TOKEN=0123456789abcdef0123456789abcdef
# Active solo cuando Core esté detrás de un proxy que sobrescriba X-Forwarded-For.
# TRUST_PROXY=1
POOL_ROOT=./data
ZIM_ENGINE=native
